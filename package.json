{
  "name": "flexlayout-react",
  "version": "0.10.0",
  "description": "A multi-tab docking layout manager",
  "author": "Caplin Systems Ltd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caplin/FlexLayout.git"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style/*": "./style/*"
  },
  "files": [
    "dist/",
    "types/",
    "style/"
  ],
  "keywords": [
    "react",
    "layout",
    "dock",
    "popout",
    "tabs",
    "tabset",
    "splitter",
    "drag",
    "drop",
    "reactjs",
    "flexlayout",
    "flex layout",
    "layout manager",
    "drag and drop",
    "split view",
    "docking library",
    "docking layout"
  ],
  "scripts": {
    "dev": "vite --host",
    "preview": "vite preview",
    "build": "npm run build:clean && npm run typecheck && npm run build:demo && npm run css && npm run build:lib && npm run build:types && npm run doc",
    "build:clean": "rimraf demo/dist dist/ types/ typedoc/",
    "build:demo": "vite build",
    "build:types": "tsc -p tsconfig-types.json",
    "build:lib": "vite build --config vite.config.lib.ts",
    "test": "vitest",
    "playwright": "playwright test --ui",
    "lint": "eslint src demo tests tests-playwright",
    "format": "prettier --write src demo tests tests-playwright",
    "format:check": "prettier --check src demo tests tests-playwright",
    "typecheck": "tsc -p tsconfig.json",
    "doc": "typedoc --out typedoc --exclude \"**/demo/**/*.tsx\" --excludeInternal --disableSources --excludePrivate --excludeProtected --readme none ./src",
    "css": "sass style:style"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1", 
    "@monaco-editor/react": "^4.7.0",
    "@mui/material": "^9.2.0",
    "@mui/x-data-grid": "^9.9.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.5",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "ag-grid-community": "^35.3.1",
    "ag-grid-react": "^35.3.1",
    "chart.js": "^4.5.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "ol": "^10.9.0",
    "prettier": "^3.9.5",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "styled-components": "^6.4.3",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
